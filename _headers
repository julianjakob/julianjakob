# Netlify HTTP headers
# Fonts are immutable — hash them in filename to bust cache when updated
/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Other static assets — 1 week, revalidate
/assets/*
  Cache-Control: public, max-age=604800

# Project media — 1 week
/projects/*
  Cache-Control: public, max-age=604800

# HTML, JS, CSS — always revalidate (no content hash in filenames)
/*.html
  Cache-Control: public, max-age=0, must-revalidate

/*.js
  Cache-Control: public, max-age=0, must-revalidate

/*.css
  Cache-Control: public, max-age=0, must-revalidate

# projects-data.json — short TTL so new projects appear quickly
/projects-data.json
  Cache-Control: public, max-age=3600, must-revalidate
